{
  "manifest_version": 3,
  "name": "GmailMod",
  "version": "1.0",
  "description": "Manage all your email subscriptions directly from the Gmail subs panel.",
  "permissions": [
    "activeTab"
  ],
  "host_permissions": [
    "https://mail.google.com/*"
  ],
  "icons": {
    "16": "icon16.png",
    "32": "icon32.png",
    "48": "icon48.png",
    "128": "icon128.png"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "32": "icon32.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://mail.google.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_end",
      "all_frames": true
    }
  ]
}